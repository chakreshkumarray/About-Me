# API Configuration
PORT=8001
HOST=0.0.0.0

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# Database Configuration
# For MySQL:
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/crm_hcp_db
# For PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/crm_hcp_db
# For SQLite (default):
# DATABASE_URL=sqlite:///./crm_hcp.db

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
